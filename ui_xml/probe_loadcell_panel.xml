<!-- Load cell probe type-specific control panel (FlashForge AD5M/AD5X, Klipper [load_cell]) -->
<component>
  <view name="probe_loadcell_panel"
        extends="lv_obj" width="100%" height="content" style_pad_all="0"
        flex_flow="column" style_pad_gap="#space_sm" scrollable="false">

    <setting_section_header title="LOAD CELL" title_tag="LOAD CELL" icon="weight"/>

    <!-- Tare + Calibrate row — 2 equal-width -->
    <lv_obj width="100%" height="content" style_pad_all="0" flex_flow="row"
            style_pad_gap="#space_sm" scrollable="false">
      <ui_button name="btn_loadcell_tare"
                 width="1" flex_grow="1" height="#button_height_sm" variant="secondary" text="Tare" translation_tag="Tare"
                 icon="weight">
        <event_cb trigger="clicked" callback="on_loadcell_tare"/>
      </ui_button>
      <ui_button name="btn_loadcell_calibrate"
                 width="1" flex_grow="1" height="#button_height_sm" variant="secondary" text="Calibrate" translation_tag="Calibrate"
                 icon="target">
        <event_cb trigger="clicked" callback="on_loadcell_calibrate"/>
      </ui_button>
    </lv_obj>

    <!-- Diagnostic — full width -->
    <ui_button name="btn_loadcell_diagnostic"
               width="100%" height="#button_height_sm" variant="secondary" text="Diagnostic" translation_tag="Diagnostic"
               icon="tune">
      <event_cb trigger="clicked" callback="on_loadcell_diagnostic"/>
    </ui_button>
  </view>
</component>
