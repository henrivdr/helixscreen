<!--
  AMS feature tokens.

  All ams_* responsive px tokens live here. Following the same convention as
  fan_tokens.xml — feature-scoped tokens go in their own file rather than
  bloating globals.xml or living inside a "consumer" panel like ams_panel.xml
  (where they used to live, but were also referenced from ams_overview_panel.xml
  and ams_slot_view.xml — backward-coupling).

  theme_manager scans every file in ui_xml/ for responsive px tokens and
  registers the bare base name (e.g. `ams_right_col_w`) into the globals scope
  per current breakpoint, so any component can reference `#ams_right_col_w`
  regardless of which file the *_tiny/*_small/etc. variants are defined in.
-->
<component>
  <consts>
    <!-- ===================================================================== -->
    <!-- Sidebar / Right Column                                                -->
    <!-- ===================================================================== -->
    <!-- Right sidebar width on ams_panel + ams_overview_panel. ~40% narrower
         at MICRO/TINY so the left content (slots + flow graphic) gets more
         horizontal room on small displays (Snapmaker U1 480x320 etc.). -->
    <px name="ams_right_col_w_micro" value="145"/>
    <px name="ams_right_col_w_tiny" value="145"/>
    <px name="ams_right_col_w_small" value="200"/>
    <px name="ams_right_col_w_medium" value="240"/>
    <px name="ams_right_col_w_large" value="240"/>

    <!-- ===================================================================== -->
    <!-- Slot Widget Dimensions (consumed by ams_slot_view.xml + ui_ams_slot.cpp) -->
    <!-- ===================================================================== -->
    <!-- Spool circle size. Previously space_lg*4 which collapsed to 32px at
         MICRO/TINY (too small for the space available). -->
    <px name="ams_slot_spool_size_micro" value="48"/>
    <px name="ams_slot_spool_size_tiny" value="48"/>
    <px name="ams_slot_spool_size_small" value="48"/>
    <px name="ams_slot_spool_size_medium" value="64"/>
    <px name="ams_slot_spool_size_large" value="80"/>

    <!-- Badge border thickness — thinner at MICRO/TINY to reclaim pixels on
         the already-small spool. -->
    <px name="ams_slot_badge_border_w_micro" value="1"/>
    <px name="ams_slot_badge_border_w_tiny" value="1"/>
    <px name="ams_slot_badge_border_w_small" value="2"/>
    <px name="ams_slot_badge_border_w_medium" value="2"/>
    <px name="ams_slot_badge_border_w_large" value="2"/>

    <!-- Badge internal padding — tight at MICRO/TINY so the single-digit
         slot number / tool label isn't swimming in whitespace. -->
    <px name="ams_slot_badge_pad_h_micro" value="2"/>
    <px name="ams_slot_badge_pad_h_tiny" value="2"/>
    <px name="ams_slot_badge_pad_h_small" value="4"/>
    <px name="ams_slot_badge_pad_h_medium" value="4"/>
    <px name="ams_slot_badge_pad_h_large" value="4"/>

    <px name="ams_slot_status_badge_size_micro" value="16"/>
    <px name="ams_slot_status_badge_size_tiny" value="16"/>
    <px name="ams_slot_status_badge_size_small" value="20"/>
    <px name="ams_slot_status_badge_size_medium" value="20"/>
    <px name="ams_slot_status_badge_size_large" value="20"/>

    <px name="ams_slot_tool_badge_h_micro" value="14"/>
    <px name="ams_slot_tool_badge_h_tiny" value="14"/>
    <px name="ams_slot_tool_badge_h_small" value="16"/>
    <px name="ams_slot_tool_badge_h_medium" value="16"/>
    <px name="ams_slot_tool_badge_h_large" value="16"/>

    <px name="ams_slot_tool_badge_min_w_micro" value="18"/>
    <px name="ams_slot_tool_badge_min_w_tiny" value="18"/>
    <px name="ams_slot_tool_badge_min_w_small" value="22"/>
    <px name="ams_slot_tool_badge_min_w_medium" value="22"/>
    <px name="ams_slot_tool_badge_min_w_large" value="22"/>

    <!-- ===================================================================== -->
    <!-- AMS Overview Card Sizes (consumed by ams_unit_card.xml + ams_overview_panel.xml) -->
    <!-- ===================================================================== -->
    <!-- Unit type logo (Box Turtle, Night Owl, etc.) -->
    <px name="ams_logo_size_small" value="20"/>
    <px name="ams_logo_size_medium" value="24"/>
    <px name="ams_logo_size_large" value="28"/>
    <px name="ams_logo_size_xlarge" value="32"/>
    <px name="ams_logo_size_xxlarge" value="40"/>

    <!-- Mini status bars container height -->
    <px name="ams_bars_height_small" value="36"/>
    <px name="ams_bars_height_medium" value="48"/>
    <px name="ams_bars_height_large" value="56"/>
    <px name="ams_bars_height_xlarge" value="68"/>
    <px name="ams_bars_height_xxlarge" value="80"/>

    <!-- Unit card min/max widths -->
    <px name="ams_card_min_width_small" value="80"/>
    <px name="ams_card_min_width_medium" value="100"/>
    <px name="ams_card_min_width_large" value="120"/>
    <px name="ams_card_min_width_xlarge" value="140"/>
    <px name="ams_card_min_width_xxlarge" value="180"/>

    <px name="ams_card_max_width_small" value="160"/>
    <px name="ams_card_max_width_medium" value="200"/>
    <px name="ams_card_max_width_large" value="240"/>
    <px name="ams_card_max_width_xlarge" value="280"/>
    <px name="ams_card_max_width_xxlarge" value="360"/>
  </consts>
</component>
