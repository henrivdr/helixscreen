<component>
  <view extends="lv_obj"
        width="100%" height="100%" style_pad_all="#space_sm" style_pad_gap="#space_sm"
        style_bg_opa="0%" scrollable="false"
        flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center">
    <!-- Primary control: Pause/Resume — icon, label, and enabled state all driven
         by the PrintControlButtons singleton's global subjects. -->
    <ui_button name="btn_primary"
               height="#button_height_lg" flex_grow="1"
               bind_icon="print_control_primary_icon" bind_text="print_control_primary_label"
               label_hidden_if_bp_eq="1">
      <event_cb trigger="clicked" callback="on_print_control_primary"/>
      <bind_state_if_eq subject="print_control_primary_enabled" state="disabled" ref_value="0"/>
    </ui_button>
    <!-- Stop control -->
    <ui_button name="btn_stop"
               height="#button_height_lg" flex_grow="1" variant="danger"
               icon="stop" text="Stop" translation_tag="Stop"
               label_hidden_if_bp_eq="1">
      <event_cb trigger="clicked" callback="on_print_control_stop"/>
      <bind_state_if_eq subject="print_control_stop_enabled" state="disabled" ref_value="0"/>
    </ui_button>
  </view>
</component>
