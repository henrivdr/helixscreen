<!-- Horizontal 3-fan info row for the print status panel. -->
<!-- Visibility is driven by print_status_fans_fit (adaptive fit calc). -->
<!-- Aux cluster is driven by print_status_aux_*_visible composite subjects. -->
<!-- Density is driven by print_status_fan_row_density (0=full,1=med,2=compact). -->
<component>
  <view name="print_status_fan_row_root"
        extends="lv_obj"
        width="100%" height="content"
        style_pad_all="0" style_pad_left="#space_xs" style_pad_right="#space_xs"
        flex_flow="row"
        style_flex_main_place="center" style_flex_cross_place="center"
        style_pad_gap="#space_xs"
        scrollable="false" clickable="true">

    <!-- Hide whole row when adaptive-fit calc says no -->
    <bind_flag_if_eq subject="print_status_fans_fit" flag="hidden" ref_value="0"/>
    <bind_state_if_not_eq subject="printer_connection_state" state="disabled" ref_value="2"/>

    <event_cb trigger="clicked" callback="on_print_status_fans_clicked"/>

    <!-- Part fan: icon (density 0 only) -->
    <icon name="part_fan_icon" src="fan" size="xs" variant="secondary"
          clickable="false" event_bubble="true">
      <bind_flag_if_not_eq subject="print_status_fan_row_density" flag="hidden" ref_value="0"/>
    </icon>
    <!-- Part fan: full label (density 0 or 1) -->
    <text_small name="part_fan_label_full" text="Part" translation_tag="Part"
                style_text_color="#primary"
                clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="print_status_fan_row_density" flag="hidden" ref_value="2"/>
    </text_small>
    <!-- Part fan: short label (density 2 only) -->
    <text_small name="part_fan_label_short" text="P"
                style_text_color="#primary"
                clickable="false" event_bubble="true">
      <bind_flag_if_not_eq subject="print_status_fan_row_density" flag="hidden" ref_value="2"/>
    </text_small>
    <text_small name="part_fan_speed" text="--"
                clickable="false" event_bubble="true"/>

    <!-- Hotend fan: icon (density 0 only) -->
    <icon name="hotend_fan_icon" src="fan" size="xs" variant="secondary"
          clickable="false" event_bubble="true">
      <bind_flag_if_not_eq subject="print_status_fan_row_density" flag="hidden" ref_value="0"/>
    </icon>
    <!-- Hotend fan: full label (density 0 or 1) -->
    <text_small name="hotend_fan_label_full" text="Hotend" translation_tag="Hotend"
                style_text_color="#primary"
                clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="print_status_fan_row_density" flag="hidden" ref_value="2"/>
    </text_small>
    <!-- Hotend fan: short label (density 2 only) -->
    <text_small name="hotend_fan_label_short" text="H"
                style_text_color="#primary"
                clickable="false" event_bubble="true">
      <bind_flag_if_not_eq subject="print_status_fan_row_density" flag="hidden" ref_value="2"/>
    </text_small>
    <text_small name="hotend_fan_speed" text="--"
                clickable="false" event_bubble="true"/>

    <!-- Aux cluster: icon + labels + speed, all hide together -->
    <!-- Aux icon: composite subject = aux_present AND density==0 -->
    <icon name="aux_fan_icon" src="fan" size="xs" variant="secondary"
          clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="print_status_aux_icon_visible" flag="hidden" ref_value="0"/>
    </icon>
    <!-- Aux full label: composite subject = aux_present AND density!=2 -->
    <text_small name="aux_fan_label_full" text="Aux" translation_tag="Aux"
                style_text_color="#primary"
                clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="print_status_aux_full_visible" flag="hidden" ref_value="0"/>
    </text_small>
    <!-- Aux short label: composite subject = aux_present AND density==2 -->
    <text_small name="aux_fan_label_short" text="A"
                style_text_color="#primary"
                clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="print_status_aux_short_visible" flag="hidden" ref_value="0"/>
    </text_small>
    <!-- Aux speed: visible when aux present (density-invariant) -->
    <text_small name="aux_fan_speed" text="--"
                clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="print_status_aux_fan_present" flag="hidden" ref_value="0"/>
    </text_small>
  </view>
</component>
