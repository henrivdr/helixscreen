<!-- Enriched pre-flight filament check modal. Shown before a print starts when
     the cached PreflightResult reports a blocking condition (a required tool
     maps to an empty slot). Per-tool rows are populated dynamically in C++. -->
<!-- NOTE: Backdrop is created programmatically by the Modal class in C++. -->
<!-- Buttons are wired programmatically in PreflightCheckModal::on_show() via -->
<!-- wire_ok_button / wire_cancel_button / wire_tertiary_button. -->
<component>
  <view name="preflight_check_modal"
        extends="ui_dialog" width="70%" height="content" align="center"
        flex_flow="column" style_flex_main_place="start" style_pad_gap="0">
    <!-- Header row with warning icon + title -->
    <modal_header icon_src="alert" icon_variant="warning"
                  title="Check filament" title_tag="Check filament"/>

    <!-- Scrollable per-tool check list -->
    <lv_obj name="preflight_tool_list" width="100%" flex_grow="1"
            style_pad_left="#space_lg" style_pad_right="#space_lg"
            style_pad_top="#space_sm" style_pad_bottom="#space_sm"
            flex_flow="column" style_pad_gap="#space_xs"
            scrollable="true" scrollbar_mode="active">
      <!-- Rows populated dynamically in C++ -->
    </lv_obj>

    <!-- Explanation line. Text set from C++ on_show(). -->
    <text_body name="preflight_explanation" width="100%" long_mode="wrap"
               style_pad_left="#space_lg" style_pad_right="#space_lg"
               style_pad_top="#space_xs" style_pad_bottom="#space_md"
               style_text_color="#text_muted"/>

    <!-- Divider above the button row -->
    <divider_horizontal/>

    <!-- Button row: Remap… (tertiary, optional), Cancel (secondary),
         Print Anyway (primary). Wired programmatically; no XML callbacks to
         avoid double-wiring. The tertiary button is hidden from C++ when the
         active backend's remap strategy is None. -->
    <lv_obj width="100%" height="#button_height" style_pad_all="0" style_pad_gap="0" flex_flow="row">
      <ui_button name="btn_tertiary" height="100%" flex_grow="1" style_radius="0"
                 style_border_width="0"
                 text="Remap…" translation_tag="Remap…"/>
      <divider_vertical/>
      <ui_button name="btn_secondary" height="100%" flex_grow="1" style_radius="0"
                 style_border_width="0"
                 text="Cancel" translation_tag="Cancel"/>
      <divider_vertical/>
      <ui_button name="btn_primary" variant="primary" height="100%" flex_grow="1"
                 style_radius="0" style_border_width="0"
                 text="Print Anyway" translation_tag="Print Anyway"/>
    </lv_obj>
  </view>
</component>
