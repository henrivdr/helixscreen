<component>
  <!-- One row of the pre-flight check modal:
         [Tx label] [intended swatch] [→] [seated swatch | EMPTY label] [severity icon]
       Colors, label texts, severity glyph/variant, and optional-child
       visibility are set from C++ in PreflightCheckModal::on_show().
       Everything visual (sizes, fonts, padding, borders, radii) lives here
       so it can be tuned without rebuilding. Modeled on
       filament_mapping_tool_row.xml. -->
  <view name="preflight_tool_row"
        extends="lv_obj" width="100%" height="content"
        flex_flow="row" style_flex_cross_place="center"
        style_pad_hor="#space_md" style_pad_ver="#space_sm"
        style_pad_gap="#space_md"
        style_radius="#space_sm"
        style_bg_color="#elevated_bg" style_bg_opa="255"
        scrollable="false" clickable="false">
    <!-- Tool index label ("T0", "T1", …). -->
    <lv_label name="tool_label"
              text="" align="center"
              style_text_font="#font_body" style_text_color="#text"
              clickable="false" event_bubble="true"/>
    <!-- Slicer-intended color swatch (bg set from C++). -->
    <lv_obj name="intended_swatch"
            width="#space_2xl" height="#space_2xl"
            style_radius="9999" style_bg_opa="255"
            style_bg_color="#text_muted"
            style_border_width="1"
            style_border_color="#text_muted" style_border_opa="30"
            style_pad_all="0"
            scrollable="false" clickable="false" event_bubble="true"/>
    <!-- Intended → seated arrow. -->
    <lv_label name="arrow"
              text="#icon_arrow_right"
              style_text_font="mdi_icons_24"
              style_text_color="#text_muted"
              clickable="false" event_bubble="true"/>
    <!-- Actually-seated slot color swatch (bg set from C++). Hidden when the
         mapped slot is empty/absent — the empty_label is shown instead. -->
    <lv_obj name="seated_swatch"
            hidden="true"
            width="#space_2xl" height="#space_2xl"
            style_radius="9999" style_bg_opa="255"
            style_bg_color="#text_muted"
            style_border_width="1"
            style_border_color="#text_muted" style_border_opa="30"
            style_pad_all="0"
            scrollable="false" clickable="false" event_bubble="true"/>
    <!-- "EMPTY" label shown when the mapped slot has no filament. -->
    <lv_label name="empty_label"
              hidden="true" text="EMPTY" translation_tag="EMPTY"
              style_text_font="#font_body" style_text_color="#warning"
              clickable="false" event_bubble="true"/>
    <!-- Severity glyph (✓ success / ⚠ warning / ✗ danger). Source + variant
         set from C++. Pushed to the trailing edge by flex_grow. -->
    <icon name="severity_icon" src="check" size="sm" variant="success"
          flex_grow="1" style_text_align="right"/>
  </view>
</component>
