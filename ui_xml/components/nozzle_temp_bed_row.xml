<component name="nozzle_temp_bed_row">
    <view extends="lv_obj" name="bed_row_root"
          width="100%" height="content" flex_flow="column"
          style_pad_all="0" style_pad_top="#space_xxs" style_pad_row="0" style_pad_column="0"
          style_bg_opa="0" style_border_width="1"
          style_border_side="top" style_border_color="#text_muted" style_border_opa="50"
          scrollable="false">
        <lv_obj width="100%" height="content" flex_flow="row"
                style_flex_main_place="space_between" style_flex_cross_place="center"
                style_pad_all="0" style_pad_row="0" style_pad_column="#space_sm"
                style_bg_opa="0" style_border_width="0"
                scrollable="false">
            <icon name="bed_icon" src="radiator" size="xs" variant="danger"/>
            <text_small name="bed_label" text="Bed" translation_tag="Bed"
                        style_text_color="#primary"
                        width="content" style_min_width="#space_xl"/>
            <text_small name="bed_temp_label" text="0°" flex_grow="1"/>
            <text_small name="bed_target_label" text="off" style_text_color="#text_muted"
                        style_text_align="right"/>
        </lv_obj>
    </view>
</component>
