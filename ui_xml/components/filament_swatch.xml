<component>
  <!-- Per-tool color chip shown in the Print File Detail FILAMENTS card.
       One instance per gcode tool used by the file. TWO-TONE chip: one
       unified tile split by a thin horizontal divider into two equal-size,
       full-bleed color bands:
         - TOP band "top_band": bg = the GCODE FILE intended color for this
           tool (slicer palette). Label "tool_label" = gcode tool number ("T0").
         - DIVIDER "divider": thin horizontal rule; color set per chip from C++.
         - BOTTOM band "bottom_band": bg = the ACTUAL present color of the
           EFFECTIVE mapped slot. Label "slot_label" = mapped lane number ("1").

       Layout: the chip has a FIXED width so both bands cross-stretch to the
       same width (full-bleed, connected — NOT content-width, which would let
       each band hug its own label, producing two disconnected mismatched-width
       boxes). Labels center via flex_grow + text_align. Bands fill the height
       via flex_grow. width="40" is tunable — the snug size that fits the widest
       label ("T31").

       C++ (update_color_swatches) owns only the dynamic data:
         - top_band bg = gcode/palette intended color
         - bottom_band bg = mapped slot present color (or empty variant)
         - tool_label text + contrast color (against top band bg)
         - slot_label text + contrast color (against bottom band bg)
         - divider bg color (contrast against a blend of both bands)
         - LV_STATE_USER_1 on bottom_band for the empty-slot variant -->
  <styles>
    <!-- Empty-slot variant on the BOTTOM band when the tool's mapped slot is
         empty: warning border + reduced bg opacity. Toggled by C++ via
         lv_obj_add_state(bottom_band, LV_STATE_USER_1). -->
    <style name="empty_slot"
           bg_opa="60"
           border_width="2" border_color="#warning" border_opa="255"/>
  </styles>
  <view name="swatch"
        extends="lv_obj" width="40" height="100%"
        flex_flow="column"
        style_flex_main_place="center" style_flex_cross_place="stretch"
        style_pad_all="0" style_pad_row="0"
        style_radius="4"
        style_bg_opa="0"
        style_border_width="0"
        style_clip_corner="true"
        scrollable="false" clickable="false" event_bubble="true">
    <!-- TOP band: gcode intended color. width="100%" makes it span the full
         chip width (the parent's style_flex_cross_place="stretch" alone does NOT
         widen a flex child whose default width is content-sized — without an
         explicit width the band collapses to 0 and the whole chip vanishes).
         L082-safe: the swatch root is a FIXED 40px width, not content-sized.
         flex_grow fills half the height (main axis of the column). -->
    <lv_obj name="top_band"
            width="100%" height="0" flex_grow="1"
            flex_flow="row"
            style_flex_main_place="center" style_flex_cross_place="center"
            style_pad_all="0"
            style_radius="0" style_bg_opa="255" style_border_width="0"
            scrollable="false" clickable="false" event_bubble="true">
      <lv_label name="tool_label"
                text="" flex_grow="1"
                style_text_align="center"
                style_text_font="#font_small"
                style_text_color="#text"
                clickable="false" event_bubble="true"/>
    </lv_obj>
    <!-- Divider: thin full-width rule (width="100%" for the same reason as the
         bands); color set per chip from C++. -->
    <lv_obj name="divider"
            width="100%" height="1"
            style_bg_color="#text_muted" style_bg_opa="255"
            style_radius="0" style_border_width="0" style_pad_all="0"
            scrollable="false" clickable="false" event_bubble="true"/>
    <!-- BOTTOM band: present color of the effective mapped slot. width="100%"
         for the same reason as the top band. -->
    <lv_obj name="bottom_band"
            width="100%" height="0" flex_grow="1"
            flex_flow="row"
            style_flex_main_place="center" style_flex_cross_place="center"
            style_pad_all="0"
            style_radius="0" style_bg_opa="255" style_border_width="0"
            scrollable="false" clickable="false" event_bubble="true">
      <style name="empty_slot" selector="user_1"/>
      <lv_label name="slot_label"
                text="" flex_grow="1"
                style_text_align="center"
                style_text_font="#font_small"
                style_text_color="#text"
                clickable="false" event_bubble="true"/>
    </lv_obj>
  </view>
</component>
