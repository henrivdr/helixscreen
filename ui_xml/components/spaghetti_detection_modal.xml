<!-- Spaghetti / print-issue detection response modal. -->
<!-- NOTE: Backdrop is created programmatically by the Modal class in C++. -->
<!-- Buttons are wired programmatically in SpaghettiDetectionModal::on_show() -->
<!-- via wire_ok_button / wire_cancel_button / wire_tertiary_button. -->
<component>
  <view name="spaghetti_detection_modal"
        extends="ui_dialog" width="70%" height="content" align="center" flex_flow="column"
        style_flex_main_place="start" style_pad_gap="0">
    <!-- Header row with warning icon + title -->
    <modal_header icon_src="alert" icon_variant="warning"
                  title="Print issue detected" title_tag="Print issue detected"/>

    <!-- Content area: optional camera frame preview + message -->
    <lv_obj width="100%" height="content"
            style_pad_left="#space_lg" style_pad_right="#space_lg"
            style_pad_top="#space_sm" style_pad_bottom="#space_lg"
            flex_flow="column" style_flex_cross_place="center" style_pad_gap="#space_md">
      <!-- Camera frame preview. Image source is fed from C++ on_show() when a
           frame is available; otherwise it stays empty. -->
      <lv_image name="detection_preview" align="center"/>
      <!-- Detection message text. Set from C++ on_show(). -->
      <text_body name="detection_text" width="100%" long_mode="wrap"
                 style_text_align="center"/>
    </lv_obj>

    <!-- Divider above the button row -->
    <divider_horizontal/>

    <!-- Button row: Resume (primary), Abort (secondary/danger), Reduce Sensitivity (tertiary).
         Wired programmatically; no XML callbacks to avoid double-wiring. -->
    <lv_obj width="100%" height="#button_height" style_pad_all="0" style_pad_gap="0" flex_flow="row">
      <ui_button name="btn_secondary" height="100%" flex_grow="1" style_radius="0"
                 style_border_width="0" variant="danger"
                 text="Abort" translation_tag="Abort"/>
      <divider_vertical/>
      <ui_button name="btn_tertiary" height="100%" flex_grow="1" style_radius="0"
                 style_border_width="0"
                 text="Reduce Sensitivity" translation_tag="Reduce Sensitivity"/>
      <divider_vertical/>
      <ui_button name="btn_primary" variant="primary" height="100%" flex_grow="1"
                 style_radius="0" style_border_width="0"
                 text="Resume" translation_tag="Resume"/>
    </lv_obj>
  </view>
</component>
