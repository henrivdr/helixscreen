<component>
  <!--
    Clog meter page content for carousel embedding.
    Contains the named objects that UiClogMeter expects to find:
    clog_meter, clog_arc_container, clog_arc, clog_value_text, clog_mode_text.
  -->
  <view name="clog_meter_page" extends="lv_obj"
        width="100%" height="100%"
        style_pad_all="0" style_pad_row="0" style_pad_column="0"
        scrollable="false" flex_flow="column"
        style_flex_main_place="center" style_flex_cross_place="center"
        style_flex_track_place="center"
        clickable="false" event_bubble="true">
    <lv_obj name="clog_meter" width="100%" height="100%"
            style_pad_all="0" style_pad_row="0" style_pad_column="0"
            style_pad_bottom="#space_lg"
            scrollable="false" flex_flow="column"
            style_flex_main_place="end" style_flex_cross_place="center"
            clickable="false" event_bubble="true">
      <bind_flag_if_eq subject="clog_meter_mode" flag="hidden" ref_value="0"/>
      <lv_obj name="clog_arc_container"
              style_pad_all="0" style_pad_top="#space_sm" scrollable="false" flex_grow="1"
              clickable="false" event_bubble="true">
        <!-- Main arc — shared helix_progress_arc handles common styling
             and diameter-driven stroke tier. UiClogMeter syncs the
             danger/peak overlay arcs (created in C++) to match. -->
        <helix_progress_arc name="clog_arc" align="center" event_bubble="true"/>
        <text_tiny name="clog_value_text" align="center"
                   bind_text="clog_meter_value_text"
                   style_text_align="center"
                   clickable="false" event_bubble="true"/>
      </lv_obj>
      <text_tiny name="clog_mode_text" width="100%"
                 bind_text="clog_meter_mode_text"
                 style_text_color="#text_muted" style_text_align="center"
                 clickable="false" event_bubble="true"/>
    </lv_obj>
  </view>
</component>
