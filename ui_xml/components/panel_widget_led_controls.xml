<component>
  <view name="panel_widget_led_controls" extends="lv_obj"
        height="100%" flex_grow="1" style_pad_all="0" scrollable="false">
    <ui_button name="led_controls_button"
               width="100%" height="100%" variant="ghost"
               flex_flow="column" style_flex_main_place="center"
               style_flex_cross_place="center" style_flex_track_place="center"
               style_border_width="0" focusable="false">
      <bind_state_if_not_eq subject="printer_connection_state" state="disabled" ref_value="2"/>
      <icon name="led_controls_icon" src="led_strip" size="#icon_size" variant="muted"/>
      <text_tiny text="LEDs" translation_tag="LEDs"
                 style_text_color="#text_muted" style_text_align="center"
                 clickable="false" event_bubble="true">
        <bind_flag_if_eq subject="show_widget_labels" flag="hidden" ref_value="0"/>
      </text_tiny>
      <event_cb trigger="clicked" callback="on_led_controls_clicked"/>
    </ui_button>
  </view>
</component>
