<!-- Modal for editing filament preset (name, nozzle temp, bed temp) -->
<!-- NOTE: Backdrop created programmatically by Modal system -->
<component>
  <consts>
    <px name="input_width" value="100"/>
  </consts>
  <!-- Dialog card (backdrop created programmatically) -->
  <view name="filament_preset_edit_modal"
        extends="ui_dialog" width="280" height="content" align="center" flex_flow="column" style_flex_main_place="start"
        style_pad_gap="0">
    <!-- Header: title + close. -->
    <modal_header title="Edit Preset" title_tag="Edit Preset"
                  hide_icon="true" hide_close="false" close_callback="filament_preset_edit_close_cb"/>
    <!-- Horizontal divider -->
    <divider_horizontal/>
    <!-- Content area -->
    <lv_obj width="100%"
            height="content" style_pad_all="#space_md" flex_flow="column" style_pad_gap="#space_md" scrollable="false">
      <!-- Name field -->
      <form_field label="Name" label_tag="Name" input_name="name_input" placeholder="PLA"/>
      <!-- Temperature row -->
      <lv_obj width="100%"
              height="content" style_pad_all="0" flex_flow="row" style_flex_main_place="space_between"
              style_pad_gap="#space_md" scrollable="false">
        <!-- Nozzle temp -->
        <lv_obj height="content" style_pad_all="0" flex_flow="column" style_pad_gap="#space_xs" scrollable="false">
          <text_small text="Nozzle °C" translation_tag="Nozzle °C"/>
          <lv_spinbox name="nozzle_spinbox"
                      width="#input_width" height="40" style_radius="#border_radius"
                      style_border_width="1" style_border_color="#text_muted" value="210" min_value="150" max_value="300" step="5"
                      digit_count="3"/>
        </lv_obj>
        <!-- Bed temp -->
        <lv_obj height="content" style_pad_all="0" flex_flow="column" style_pad_gap="#space_xs" scrollable="false">
          <text_small text="Bed °C" translation_tag="Bed °C"/>
          <lv_spinbox name="bed_spinbox"
                      width="#input_width" height="40" style_radius="#border_radius"
                      style_border_width="1" style_border_color="#text_muted" value="60" min_value="0" max_value="120" step="5"
                      digit_count="3"/>
        </lv_obj>
      </lv_obj>
    </lv_obj>
    <modal_button_row primary_text="Save"
                      secondary_text="Cancel" primary_callback="filament_preset_edit_save_cb"
                      secondary_callback="filament_preset_edit_close_cb"/>
  </view>
</component>
