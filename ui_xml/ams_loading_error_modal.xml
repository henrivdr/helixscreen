<!-- Modal for displaying AMS loading errors with retry option -->
<!-- NOTE: Backdrop created programmatically by Modal system -->
<component>
  <!-- Dialog card -->
  <view name="ams_loading_error_modal"
        extends="ui_dialog" width="360" height="content" align="center" flex_flow="column" style_flex_main_place="start"
        style_pad_gap="0">
    <!-- Header: danger icon + title + close. Close wired in C++ via wire_cancel_button("btn_close"). -->
    <modal_header icon_src="alert_circle" icon_variant="danger"
                  title="Loading Error" title_tag="Loading Error" hide_close="false"/>
    <!-- Horizontal divider -->
    <divider_horizontal/>
    <!-- Error message content -->
    <lv_obj width="100%"
            height="content" style_pad_all="#space_lg" flex_flow="column" style_pad_gap="#space_md" scrollable="false">
      <!-- Error message text -->
      <text_body name="error_message"
                 width="100%" text="An error occurred while loading filament."
                 translation_tag="An error occurred while loading filament." long_mode="wrap"/>
      <!-- Hint text -->
      <text_small name="error_hint"
                  width="100%" text="Check the filament path and try again."
                  translation_tag="Check the filament path and try again." style_text_color="#text_muted"
                  long_mode="wrap"/>
    </lv_obj>
    <!-- Action buttons (wired in C++ via wire_ok/cancel_button) -->
    <modal_button_row secondary_text="Close"
                      secondary_callback="on_modal_cancel_clicked" primary_text="Retry"
                      primary_callback="on_modal_ok_clicked"/>
  </view>
</component>
