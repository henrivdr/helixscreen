diff --git a/Makefile b/Makefile
index c06b8a7..c50b3ec 100644
--- a/Makefile
+++ b/Makefile
@@ -2,6 +2,9 @@ include config.mk
 include Makefile.vars
 
 MAKEF=$(MAKE) -f Makefile.in
+# Allow callers to force static-only outputs (used by cross builds that only
+# consume libhv.a and may ship static-only OpenSSL toolchains).
+LIBHV_TARGET_TYPE ?= SHARED|STATIC
 ALL_SRCDIRS=. base ssl event event/kcp util cpputil evpp protocol http http/client http/server mqtt
 CORE_SRCDIRS=. base ssl event
 ifeq ($(WITH_KCP), yes)
@@ -84,7 +87,7 @@ prepare:
 
 libhv:
 	$(MKDIR) lib
-	$(MAKEF) TARGET=$@ TARGET_TYPE="SHARED|STATIC" SRCDIRS="$(LIBHV_SRCDIRS)"
+	$(MAKEF) TARGET=$@ TARGET_TYPE="$(LIBHV_TARGET_TYPE)" SRCDIRS="$(LIBHV_SRCDIRS)"
 	$(MKDIR) include/hv
 	$(CP) $(LIBHV_HEADERS) include/hv
 	@echo "make libhv done."
diff --git a/Makefile.in b/Makefile.in
index cceb29d..f67adc1 100644
--- a/Makefile.in
+++ b/Makefile.in
@@ -107,7 +107,9 @@ else
 endif
 
 INCDIR = include
-LIBDIR = lib
+# LIBDIR is where the linked archive/shared lib lands. Overridable so per-arch
+# out-of-tree builds (see OBJDIR) can keep their libhv.a from colliding.
+LIBDIR ?= lib
 SRCDIR = src
 BINDIR = bin
 DEPDIR = 3rd
@@ -124,10 +126,15 @@ ifeq ($(ALL_SRCS), )
 	ALL_SRCS = $(wildcard *.c *.cc *.cpp)
 endif
 override SRCS += $(filter-out %_test.c %_test.cc %_test.cpp, $(ALL_SRCS))
+# OBJDIR lets downstream build systems compile objects (and the archive) out of
+# tree so that multiple architectures (native x86_64 vs cross aarch64/arm/mips)
+# never clobber each other's .o or libhv.a. Defaults to "." so behavior is
+# unchanged when not overridden.
+OBJDIR ?= .
 # OBJS += $(patsubst %.c, %.o, $(SRCS))
 # OBJS += $(patsubst %.cc, %.o, $(SRCS))
 # OBJS += $(patsubst %.cpp, %.o, $(SRCS))
-OBJS := $(addsuffix .o, $(basename $(SRCS)))
+OBJS := $(addprefix $(OBJDIR)/, $(addsuffix .o, $(basename $(SRCS))))
 DEPS := $(OBJS:.o=.d)
 
 INSTALLED_INCS=$(addprefix $(PREFIX)/$(INCDIR)/, $(shell ls $(INCDIR)))
@@ -180,7 +187,9 @@ endif
 
 ifeq ($(WITH_OPENSSL), yes)
 	CPPFLAGS += -DWITH_OPENSSL
-	LDFLAGS += -lssl -lcrypto
+	# Allow downstream build systems to force static archives or alternate paths.
+	OPENSSL_LIBS ?= -lssl -lcrypto
+	LDFLAGS += $(OPENSSL_LIBS)
 else
 ifeq ($(WITH_GNUTLS), yes)
 	CPPFLAGS += -DWITH_GNUTLS
@@ -258,7 +267,22 @@ default: all
 all: prepare $(TARGET)
 
 prepare:
-	$(MKDIR) $(BINDIR) $(LIBDIR)
+	$(MKDIR) $(BINDIR) $(LIBDIR) $(OBJDIR)
+
+# Explicit out-of-tree compile rules. When OBJDIR != ".", the object paths are
+# prefixed (e.g. build/libhv-objs/base/hsocket.o) and no longer match GNU make's
+# built-in implicit %.o:%.c rule, so we mirror it here. Each rule creates the
+# object's destination directory first. These mirror the flags the implicit
+# rules used ($(CPPFLAGS) $(CFLAGS)/$(CXXFLAGS) -c).
+$(OBJDIR)/%.o: %.c
+	@$(MKDIR) $(dir $@)
+	$(CC) $(CPPFLAGS) $(CFLAGS) -c $< -o $@
+$(OBJDIR)/%.o: %.cc
+	@$(MKDIR) $(dir $@)
+	$(CXX) $(CPPFLAGS) $(CXXFLAGS) -c $< -o $@
+$(OBJDIR)/%.o: %.cpp
+	@$(MKDIR) $(dir $@)
+	$(CXX) $(CPPFLAGS) $(CXXFLAGS) -c $< -o $@
 
 $(TARGET): $(OBJS)
 ifneq ($(findstring SHARED, $(TARGET_TYPE)), )
@@ -287,6 +311,9 @@ endif
 
 clean:
 	$(RM) $(OBJS) $(DEPS)
+ifneq ($(OBJDIR), .)
+	$(RM) $(OBJDIR)
+endif
 	#$(RM) $(LIBDIR)
 	#$(RM) $(BINDIR)
 
