--- a/src/layouts/grid/lv_grid.c
+++ b/src/layouts/grid/lv_grid.c
@@ -14,6 +14,11 @@
 #include "../lv_layout.h"
 #include "../../core/lv_obj_private.h"
 #include "../../core/lv_global.h"
+
+/* Telemetry hook provided by helix_lvgl_anomaly.cpp — reports LVGL anomalies
+ * with backtrace + device context for remote crash diagnostics. */
+extern void helix_lvgl_anomaly(const char * code, const char * context);
+
 /*********************
  *      DEFINES
  *********************/
@@ -190,6 +195,17 @@ static void grid_update(lv_obj_t * cont, void * user_data)
     LV_LOG_INFO("update %p container", (void *)cont);
     LV_UNUSED(user_data);
 
+    /* Guard against a freed grid container reaching this callback when a
+     * relayout races teardown (modal close / panel rebuild during an AMS
+     * update). cont->spec_attr is then freed garbage and the child loop below
+     * reads a wild pointer -> SIGSEGV (#973). lv_obj_is_valid() compares the
+     * pointer against live objects without dereferencing it, so it is safe to
+     * call on a dangling pointer. */
+    if(cont == NULL || !lv_obj_is_valid(cont)) {
+        helix_lvgl_anomaly("grid_update_invalid_cont", "grid_update: container freed/invalid");
+        return;
+    }
+
     lv_grid_calc_t c;
     lv_result_t res = calc(cont, &c);
     if(res != LV_RESULT_OK) return;
@@ -207,6 +223,12 @@ static void grid_update(lv_obj_t * cont, void * user_data)
     uint32_t i;
     for(i = 0; i < cont->spec_attr->child_cnt; i++) {
         lv_obj_t * item = cont->spec_attr->children[i];
+        /* A child freed mid-relayout (async-deleted during teardown) can leave a
+         * dangling entry here; item_repos() would dereference it -> SIGSEGV (#973). */
+        if(item == NULL || !lv_obj_is_valid(item)) {
+            helix_lvgl_anomaly("grid_update_invalid_item", "grid_update: child freed/invalid");
+            continue;
+        }
         item_repos(item, &c, &hint);
     }
     calc_free(&c);
@@ -304,6 +326,16 @@ static lv_result_t calc_cols(lv_obj_t * cont, lv_grid_calc_t * c)
     int32_t cont_w = lv_obj_get_content_width(cont);
 
     c->col_num = count_tracks(col_templ);
+    /* An empty column template ({LV_GRID_TEMPLATE_LAST}) yields 0 tracks.
+     * grid_align() then evaluates `track_num - 1` as a uint32_t, underflowing to
+     * 0xFFFFFFFF, and its position loop writes ~4 billion entries past the track
+     * arrays -> SIGSEGV walking off the heap end (bundle FHWM8JVG). Bail so
+     * grid_update() skips this degenerate grid before grid_align()/item_repos(). */
+    if(c->col_num == 0) {
+        helix_lvgl_anomaly("grid_update_zero_cols", "calc_cols: empty grid template (0 tracks)");
+        if(subgrid) lv_free((void *)col_templ);
+        return LV_RESULT_INVALID;
+    }
     c->x = lv_malloc(sizeof(int32_t) * c->col_num);
     c->w = lv_malloc(sizeof(int32_t) * c->col_num);
 
@@ -316,6 +348,14 @@ static lv_result_t calc_cols(lv_obj_t * cont, lv_grid_calc_t * c)
             uint32_t ci;
             for(ci = 0; ci < lv_obj_get_child_count(cont); ci++) {
                 lv_obj_t * item = lv_obj_get_child(cont, ci);
+                /* A child freed mid-relayout (async-deleted during teardown) can leave a
+                 * dangling entry here. This calc() content-sizing pass runs before
+                 * grid_update's item_repos guard, so the deref below is otherwise
+                 * unprotected and SIGSEGVs on a page-returned object (#1001). */
+                if(item == NULL || !lv_obj_is_valid(item)) {
+                    helix_lvgl_anomaly("grid_update_invalid_calc_item", "calc_cols: child freed/invalid");
+                    continue;
+                }
                 if(lv_obj_has_flag_any(item, LV_OBJ_FLAG_IGNORE_LAYOUT | LV_OBJ_FLAG_HIDDEN | LV_OBJ_FLAG_FLOATING)) continue;
                 uint32_t col_span = get_col_span(item);
                 if(col_span != 1) continue;
@@ -395,6 +435,15 @@ static lv_result_t calc_rows(lv_obj_t * cont, lv_grid_calc_t * c)
     }
 
     c->row_num = count_tracks(row_templ);
+    /* See calc_cols: an empty row template ({LV_GRID_TEMPLATE_LAST}) yields 0
+     * tracks, underflowing grid_align()'s `track_num - 1` and walking off the
+     * heap (bundle FHWM8JVG). calc_rows() runs before any other allocation here,
+     * so bailing now is fully clean. */
+    if(c->row_num == 0) {
+        helix_lvgl_anomaly("grid_update_zero_rows", "calc_rows: empty grid template (0 tracks)");
+        if(subgrid) lv_free((void *)row_templ);
+        return LV_RESULT_INVALID;
+    }
     c->y = lv_malloc(sizeof(int32_t) * c->row_num);
     c->h = lv_malloc(sizeof(int32_t) * c->row_num);
     /*Set sizes for CONTENT cells*/
@@ -406,6 +455,14 @@ static lv_result_t calc_rows(lv_obj_t * cont, lv_grid_calc_t * c)
             uint32_t ci;
             for(ci = 0; ci < lv_obj_get_child_count(cont); ci++) {
                 lv_obj_t * item = lv_obj_get_child(cont, ci);
+                /* A child freed mid-relayout (async-deleted during teardown) can leave a
+                 * dangling entry here. This calc() content-sizing pass runs before
+                 * grid_update's item_repos guard, so the deref below is otherwise
+                 * unprotected and SIGSEGVs on a page-returned object (#1001). */
+                if(item == NULL || !lv_obj_is_valid(item)) {
+                    helix_lvgl_anomaly("grid_update_invalid_calc_item", "calc_rows: child freed/invalid");
+                    continue;
+                }
                 if(lv_obj_has_flag_any(item, LV_OBJ_FLAG_IGNORE_LAYOUT | LV_OBJ_FLAG_HIDDEN | LV_OBJ_FLAG_FLOATING)) continue;
                 uint32_t row_span = get_row_span(item);
                 if(row_span != 1) continue;
@@ -482,6 +539,29 @@ static void item_repos(lv_obj_t * item, lv_grid_calc_t * c, item_repos_hint_t *
     lv_grid_align_t col_align = get_cell_col_align(item);
     lv_grid_align_t row_align = get_cell_row_align(item);
 
+    /* Guard against a cell position/span that exceeds the calculated track
+     * count. calc() sizes c->x/c->w/c->y/c->h to col_num/row_num only; it never
+     * validates that each item's cell actually fits. An item can carry a stale
+     * or garbage cell position — e.g. a still-valid object whose grid-cell style
+     * was never set (read back as a huge default), or a position approved
+     * against a larger logical grid than the live descriptor — and the c->x[...]
+     * /c->y[...] reads below would then walk off the heap end -> SIGSEGV
+     * (bundle P234RYCL, AD5X). lv_obj_is_valid() in grid_update() catches freed
+     * children; this catches valid children with out-of-range cells. */
+    if(col_pos >= c->col_num || row_pos >= c->row_num ||
+       col_pos + col_span > c->col_num || row_pos + row_span > c->row_num) {
+        /* Include the actual cell vs. track counts so the next bundle reveals
+         * which dimension overflowed and by how much — that points at the
+         * upstream producer of the bad cell (column- vs row-sizing path). */
+        char ctx[96];
+        lv_snprintf(ctx, sizeof(ctx),
+                    "item_repos: cell out of range col=%u+%u/%u row=%u+%u/%u",
+                    (unsigned)col_pos, (unsigned)col_span, (unsigned)c->col_num,
+                    (unsigned)row_pos, (unsigned)row_span, (unsigned)c->row_num);
+        helix_lvgl_anomaly("grid_update_cell_oob", ctx);
+        return;
+    }
+
     int32_t col_x1 = 0;
     int32_t col_x2 = 0;
     int32_t col_w = 0;
