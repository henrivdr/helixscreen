+                            display_num, x_pos, y_pos,
+                            display_bounds.w, display_bounds.h,
+                            display_bounds.x, display_bounds.y);
+            } else {
+                LV_LOG_WARN("Failed to get bounds for display %d, using SDL_WINDOWPOS_CENTERED", display_num);
